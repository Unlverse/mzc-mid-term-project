generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ReservationStatus {
  CONFIRMED
  CANCELED
  ARRIVED
  NO_SHOW
}

model ManagerAccount {
  id           BigInt   @id @default(autoincrement())
  loginId      String   @unique @db.VarChar(100)
  passwordHash String   @db.VarChar(255)
  name         String   @db.VarChar(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ReservationSetting {
  id                   BigInt   @id @default(autoincrement())
  reservationStartTime String   @db.VarChar(5)
  reservationEndTime   String   @db.VarChar(5)
  slotIntervalMinutes  Int
  slotCapacity         Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ReservationDailySequence {
  id           BigInt   @id @default(autoincrement())
  sequenceDate DateTime @db.Date
  lastSequence Int
  updatedAt    DateTime @updatedAt

  @@unique([sequenceDate])
}

model Reservation {
  id                    BigInt            @id @default(autoincrement())
  reservationNumber     String            @unique @db.VarChar(30)
  reservationDate       DateTime          @db.Date
  reservationTime       String            @db.VarChar(5)
  customerName          String            @db.VarChar(100)
  customerPhone         String            @db.VarChar(20)
  partySize             Int
  temporaryPasswordHash String            @db.VarChar(255)
  status                ReservationStatus @default(CONFIRMED)
  canceledAt            DateTime?
  arrivedAt             DateTime?
  noShowAt              DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([reservationDate, reservationTime, status])
  @@index([customerPhone])
  @@index([status, createdAt])
}
